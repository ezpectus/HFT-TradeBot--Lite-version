# ── HFT Trade Bot Production Dockerfile (C++) ──
# Builder and runtime use the SAME Debian release (bookworm) to avoid ABI
# mismatches between libfmt/spdlog/yaml-cpp/boost versions across stages.
FROM gcc:14-bookworm AS builder

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake libboost-system-dev libboost-random-dev libssl-dev \
    libspdlog-dev libfmt-dev nlohmann-json3-dev \
    libyaml-cpp-dev libwebsocketpp-dev libasio-dev \
    && rm -rf /var/lib/apt/lists/*

COPY . .

# Patch websocketpp C++17/C++20 incompatibility (template-id not allowed in constructor/destructor)
RUN sed -i 's/endpoint<connection,config>/endpoint/g' /usr/include/websocketpp/endpoint.hpp \
    && sed -i 's/basic<concurrency,names>/basic/g' /usr/include/websocketpp/logger/basic.hpp \
    && sed -i 's/stub<concurrency,names>/stub/g' /usr/include/websocketpp/logger/stub.hpp || true

RUN cmake -B build -DCMAKE_BUILD_TYPE=Release \
    -DUSE_CCACHE=OFF -DUSE_UNITY_BUILD=OFF \
    && cmake --build build -j$(nproc) --target hft_trade_bot

# ── Runtime stage — same Debian release as builder to keep ABI stable ──
FROM debian:bookworm-slim

WORKDIR /app

# Pin runtime library versions to match bookworm's -dev packages from builder stage
RUN apt-get update && apt-get install -y --no-install-recommends \
    libboost-system1.74.0 libboost-random1.74.0 libssl3 libspdlog1.11 \
    libyaml-cpp0.7 libfmt9 wget ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd -r appuser && useradd -r -g appuser appuser

COPY --from=builder /app/build/hft_trade_bot /app/hft_trade_bot
COPY --from=builder /app/config /app/config

RUN chown -R appuser:appuser /app

USER appuser

EXPOSE 9091

HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=10s \
    CMD wget -q --spider http://localhost:9091/health || exit 1

CMD ["/app/hft_trade_bot", "config/config.prod.yaml"]
